---
const links = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#contact', label: 'Contact' },
];
---
<nav class="nav">
  <div class="nav-inner container">
    <a href="#top" class="brand">
      <span class="brand-mark">Z</span>
      <span class="brand-name">zhaohui</span>
    </a>
    <div class="nav-links">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: rgba(11, 11, 18, 0.6);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--gradient);
    display: grid;
    place-items: center;
    color: white;
    font-size: 15px;
    font-weight: 700;
  }
  .brand-name {
    font-size: 15px;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    font-size: 14px;
    color: var(--ink-soft);
  }
  .nav-links a {
    transition: color 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  @media (max-width: 540px) {
    .nav-links { gap: 16px; font-size: 13px; }
    .brand-name { display: none; }
  }
</style>
