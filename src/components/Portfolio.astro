---
// Edit here: your projects. Each entry can use `link` to point to a case study or live URL.
const projects = [
  {
    title: 'Messaging at Rednote',
    summary: 'Owning iOS messaging for an industrial-scale social app — message rendering, local storage, and the small details that make a chat feel alive.',
    tags: ['iOS', '2025 — Now'],
    link: '#',
  },
  {
    title: 'AI Agent Chat',
    summary: 'Built end-to-end iOS support for AI conversations, including stream-based message push. Exploring where social and AI naturally meet.',
    tags: ['iOS', 'AI'],
    link: '#',
  },
  {
    title: 'Secure Code with LLMs',
    summary: 'Co-authored research (EASE 2025) on whether language models can write secure Python — and showed that a multi-model "generate, then repair" loop substantially raises the bar.',
    tags: ['Research', 'EASE 2025'],
    link: '#',
  },
  {
    title: 'Adaptive Batching for Edge MVS',
    summary: 'Undergraduate thesis. A dynamic-programming scheduler for distributed multi-view video summarization on Jetson AGX Xavier — 18% less energy, 49% lower latency.',
    tags: ['Edge Computing', 'Thesis'],
    link: '#',
  },
];
---
<section id="work" class="section work">
  <div class="container">
    <span class="eyebrow">02 — Selected Work</span>
    <h2 class="section-title">Things I've made</h2>
    <p class="section-sub">A few projects from the past couple of years — production work, research, things in between.</p>

    <div class="grid">
      {projects.map((p, i) => (
        <a href={p.link} class={`card accent-${i % 4}`}>
          <div class="card-bg" aria-hidden="true"></div>
          <div class="card-body">
            <div class="card-tags">
              {p.tags.map(t => <span>{t}</span>)}
            </div>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-summary">{p.summary}</p>
            <span class="card-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    backdrop-filter: blur(10px);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    transition: transform 0.3s ease, border-color 0.3s ease;
    isolation: isolate;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }
  .card-bg {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    transition: opacity 0.4s ease, transform 0.6s ease;
    z-index: -1;
  }
  .card:hover .card-bg {
    opacity: 0.55;
    transform: scale(1.05);
  }
  .accent-0 .card-bg {
    background: radial-gradient(circle at 20% 20%, #7c5cff, transparent 55%),
                radial-gradient(circle at 90% 80%, #22d3ee, transparent 60%);
  }
  .accent-1 .card-bg {
    background: radial-gradient(circle at 80% 20%, #f471b5, transparent 55%),
                radial-gradient(circle at 20% 90%, #fb923c, transparent 60%);
  }
  .accent-2 .card-bg {
    background: radial-gradient(circle at 30% 80%, #34d399, transparent 55%),
                radial-gradient(circle at 80% 20%, #22d3ee, transparent 60%);
  }
  .accent-3 .card-bg {
    background: radial-gradient(circle at 70% 30%, #22d3ee, transparent 55%),
                radial-gradient(circle at 30% 90%, #7c5cff, transparent 60%);
  }
  .card-body {
    position: absolute;
    inset: 0;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .card-tags {
    position: absolute;
    top: 24px;
    left: 28px;
    display: flex;
    gap: 8px;
  }
  .card-tags span {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: rgba(11, 11, 18, 0.55);
    color: var(--ink-soft);
    backdrop-filter: blur(6px);
  }
  .card-title {
    font-size: 26px;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .card-summary {
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.55;
    max-width: 36ch;
  }
  .card-arrow {
    position: absolute;
    top: 24px;
    right: 28px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(11, 11, 18, 0.6);
    border: 1px solid var(--border-strong);
    display: grid;
    place-items: center;
    font-size: 14px;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .card:hover .card-arrow {
    transform: rotate(-45deg);
    background: var(--ink);
    color: var(--bg);
  }
  @media (max-width: 720px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card { aspect-ratio: 3 / 2; }
  }
</style>
