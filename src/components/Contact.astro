---
// Edit here: your email and social links.
const email = 'pc0581914@gmail.com';
const socials = [
  { label: 'GitHub',   href: 'https://github.com/EnzoG10' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/enzo-gong-28b65933b' },
];
---
<section id="contact" class="section contact">
  <div class="container">
    <div class="contact-card">
      <span class="eyebrow">03 · Get in touch</span>
      <h2 class="title">
        Got an idea? <br>
        <span class="accent-text">Let's talk.</span>
      </h2>
      <p class="sub">Collaborations, consulting, or a simple hello — all welcome. I read every email.</p>

      <a href={`mailto:${email}`} class="email-pill">
        <span>{email}</span>
        <span class="arrow">→</span>
      </a>

      <ul class="socials">
        {socials.map(s => (
          <li><a href={s.href} target="_blank" rel="noreferrer">{s.label} <span>↗</span></a></li>
        ))}
      </ul>
    </div>

    <footer class="foot">
      © {new Date().getFullYear()} Zhaohui Gong · Built with Astro · Hosted on GitHub Pages
    </footer>
  </div>
</section>

<style>
  .contact { padding-bottom: 48px; }

  .contact-card {
    background: var(--bg-soft);
    border-radius: var(--radius-xl);
    padding: 64px;
    margin-top: 24px;
  }

  .title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 16px 0 16px;
    color: var(--ink);
  }
  .sub {
    color: var(--ink-soft);
    font-size: 16px;
    margin-bottom: 40px;
    max-width: 480px;
    line-height: 1.6;
  }

  .email-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background: var(--ink);
    color: #ffffff;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 32px;
    transition: all 0.2s ease;
  }
  .email-pill:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }
  .email-pill .arrow {
    transition: transform 0.2s ease;
  }
  .email-pill:hover .arrow {
    transform: translateX(4px);
  }

  .socials {
    list-style: none;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: #ffffff;
    border-radius: 999px;
    font-size: 14px;
    color: var(--ink);
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .socials a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .socials span {
    color: var(--ink-mute);
    font-size: 12px;
  }
  .socials a:hover span {
    color: var(--accent);
  }

  .foot {
    color: var(--ink-mute);
    font-size: 12px;
    padding: 32px 0 16px;
    text-align: center;
  }

  @media (max-width: 720px) {
    .contact-card { padding: 40px 28px; }
  }
</style>
