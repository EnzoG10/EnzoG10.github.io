---
// Edit here: your email and social links.
const email = 'pc0581914@gmail.com';
const socials = [
  { label: 'GitHub',   href: 'https://github.com/EnzoG10' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/enzo-gong-28b65933b' },
];
---
<section id="contact" class="section contact">
  <div class="container">
    <span class="eyebrow">03 — Get in touch</span>
    <h2 class="section-title">
      <span>Got an idea?</span>
      <span class="gradient-text">Let's talk.</span>
    </h2>
    <p class="section-sub">Collaborations, consulting, or a simple hello — all welcome. I read every email.</p>

    <a href={`mailto:${email}`} class="email-link">
      <span class="email-text">{email}</span>
      <span class="email-arrow">↗</span>
    </a>

    <ul class="socials">
      {socials.map(s => (
        <li><a href={s.href} target="_blank" rel="noreferrer">{s.label} <span>↗</span></a></li>
      ))}
    </ul>

    <footer class="foot">
      © {new Date().getFullYear()} Zhaohui Gong · Built with Astro · Hosted on GitHub Pages
    </footer>
  </div>
</section>

<style>
  .contact {
    padding-bottom: 64px;
  }
  .section-title {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }
  .email-link {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    margin: 16px 0 48px;
    font-size: clamp(28px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .email-link:hover {
    border-color: var(--ink);
  }
  .email-arrow {
    font-size: 0.6em;
    color: var(--ink-soft);
    transition: transform 0.2s ease;
  }
  .email-link:hover .email-arrow {
    transform: translate(4px, -4px);
    color: var(--ink);
  }

  .socials {
    list-style: none;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 80px;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    font-size: 13px;
    color: var(--ink-soft);
    transition: all 0.2s ease;
  }
  .socials a:hover {
    color: var(--ink);
    background: var(--bg-card);
    transform: translateY(-2px);
  }
  .socials span {
    opacity: 0.6;
    font-size: 11px;
  }

  .foot {
    color: var(--ink-mute);
    font-size: 12px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>
