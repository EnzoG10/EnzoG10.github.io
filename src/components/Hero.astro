---
// Edit here: your name, role, and tagline.
const name = 'Zhaohui Gong';
const role = 'iOS Engineer @ Rednote';
const tagline = 'I write software for the small moments people spend talking to each other.';
---
<section id="top" class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <span class="status">
        <span class="status-dot"></span>
        Shanghai · Open to chat
      </span>
      <h1 class="title">
        Hi, I'm <span class="name">{name}</span><span class="period">.</span>
      </h1>
      <p class="role">{role}</p>
      <p class="tagline">{tagline}</p>
      <div class="cta-row">
        <a href="#work" class="btn btn-primary">See my work</a>
        <a href="#contact" class="btn btn-ghost">Get in touch →</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="avatar-frame">
        <img src="/avatar-portrait.jpg" alt="Zhaohui Gong" loading="eager" />
        <div class="avatar-tag">
          <img class="avatar-mini" src="/avatar-square.jpg" alt="" />
          <div class="avatar-tag-text">
            <span class="avatar-tag-name">Enzo Gong</span>
            <span class="avatar-tag-sub">Class of 2025 · BUAA</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding: 96px 0 64px;
    background: var(--bg);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .hero-text {
    max-width: 620px;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 32px;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .title {
    font-size: clamp(40px, 6.5vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--ink);
  }
  .title .name { color: var(--ink); }
  .title .period { color: var(--accent); }

  .role {
    color: var(--ink-soft);
    font-size: clamp(16px, 2vw, 18px);
    margin-bottom: 12px;
    font-weight: 500;
  }
  .tagline {
    color: var(--ink-mute);
    font-size: 15px;
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 520px;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 13px 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: #ffffff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
  .btn-ghost {
    color: var(--ink);
  }
  .btn-ghost:hover {
    color: var(--accent);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }
  .avatar-frame {
    position: relative;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: var(--bg-soft);
  }
  .avatar-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .avatar-tag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px 10px 10px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 999px;
  }
  .avatar-mini {
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    object-fit: cover;
    object-position: center 30%;
    flex-shrink: 0;
  }
  .avatar-tag-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    overflow: hidden;
  }
  .avatar-tag-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
  }
  .avatar-tag-sub {
    font-size: 11px;
    color: var(--ink-mute);
    margin-top: 2px;
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-visual {
      order: -1;
    }
    .avatar-frame {
      max-width: 280px;
    }
  }
</style>
