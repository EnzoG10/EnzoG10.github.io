---
// Edit here: your bio. Keep it short — three short paragraphs is plenty.
const paragraphs = [
  "I'm an iOS engineer at Rednote (Xiaohongshu), working on the messaging stack and on AI agent chat — the kind of features millions of people use without ever thinking about the code underneath.",
  "Before that I studied Computer Science at Beihang University. I co-authored a paper on LLMs and secure code (EASE 2025), and my undergraduate thesis built an adaptive batching mechanism for energy-efficient video summarization on edge devices.",
  "I like the quiet craft of making fast, considered software. When I'm not shipping, I sing in two college a cappella groups — it keeps the rest of life in tune.",
];

const facts = [
  { k: 'Now', v: 'iOS @ Rednote, Shanghai' },
  { k: 'Studied', v: 'CS @ Beihang University' },
  { k: 'Stack', v: 'Swift · Objective-C · TypeScript' },
  { k: 'Off the clock', v: 'Choir, a cappella, long walks' },
];
---
<section id="about" class="section about">
  <div class="container">
    <span class="eyebrow">01 · About</span>
    <h2 class="section-title">A little about me<span class="accent-text">.</span></h2>
    <div class="grid-2">
      <div class="bio">
        {paragraphs.map(p => <p>{p}</p>)}
      </div>
      <div class="facts-card">
        <ul class="facts">
          {facts.map(f => (
            <li>
              <span class="k">{f.k}</span>
              <span class="v">{f.v}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .grid-2 {
    margin-top: 24px;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .bio p {
    color: var(--ink-soft);
    font-size: 17px;
    line-height: 1.8;
    margin-bottom: 18px;
    max-width: 56ch;
  }
  .bio p:last-child { margin-bottom: 0; }

  .facts-card {
    background: var(--bg-soft);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
  }
  .facts {
    list-style: none;
  }
  .facts li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .facts li:first-child { padding-top: 0; }
  .facts li:last-child { border-bottom: none; padding-bottom: 0; }
  .facts .k {
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
    font-weight: 500;
  }
  .facts .v {
    color: var(--ink);
    font-weight: 500;
    font-size: 15px;
  }
  @media (max-width: 760px) {
    .grid-2 {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .facts-card { padding: 24px; }
  }
</style>
